                          {
                            "value": {
                              "name": "$data#$.Colophon.Person.name['`@value']",
                              "uri": "$data#$.Colophon.Person.uri['`@value']",
                              "personType": "$data#$.Colophon.Person.personType['`@value']"
                            },
                            "type": "person",
                            "label": "screens.manuscript-details.contents.Source.ManuscriptDescription.Contents.Item.Colophon.person"
                          },
                          {
                            "value": "$data#$.Colophon.Note.note['`@value']",
                            "type": "label"
                          }
                        ]
                      }
                    ]
                  }
                }
              }
            ]
          }
        ]
      },
      {
        "displayType": "group",
        "groupId": "history",
        "columns": [
          {
            "elements": [
              {
                "type": "array",
                "value": "$data#$.Source.History.Origin.Part",
                "config": {
                  "itemTemplate": {
                    "rows": [
                      {
                        "elements": [
                          {
                            "value": "$itemData#$.origPlace['`@value']",
                            "type": "label"
                          },
                          {
                            "value": "$itemData#$.origDate['`@value']",
                            "type": "label"
                          },
                          {
                            "value": "$itemData#$.note['`@value']",
                            "type": "label"
                          }
                        ]
                      }
                    ]
                  }
                }
              },
              {
                "type": "array",
                "value": "$data#$.Source.History.Provenance",
                "config": {
                  "itemTemplate": {
                    "rows": [
                      {
                        "elements": [
                          {
                            "value": "$itemData#$.provenance['`@value']",
                            "type": "label"
