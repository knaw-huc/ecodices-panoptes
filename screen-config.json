                          {
                            "value": "$itemData#$.DecoDesc.decoNote['`@value']",
                            "type": "label"
                          }
                        ]
                      },
                      {
                        "elements": [
                          {
                            "type": "array",
                            "value": "$itemData#$.DecoDesc.DecoElement",
                            "config": {
                              "itemTemplate": {
                                "type": {
                                  "value": "$itemData#$.decoType['`@value']",
                                  "type": "label"
                                },
                                "locus": {
                                  "value": "$itemData#$.Locus.locus['`@value']",
                                  "type": "label"
                                }
                              }
                            }
                          }
                        ]
                      }
                    ]
                  }
                }
              },
              {
                "value": "$data#$.Source.PhysDesc.BindingDesc.Binding.bindingDescription['`@value']",
                "type": "label"
              },
              {
                "value": "$data#$.Source.PhysDesc.BindingDesc.Binding.date['`@value']",
                "type": "label"
              },
              {
                "value": {
                  "name": "$data#$.Source.PhysDesc.BindingDesc.Person.name['`@value']",
