                          {
                            "value": "$itemData#$.HandDesc.HandNote.script['`@value']",
                            "type": "label"
                          },
                          {
                            "value": "$itemData#$.HandDesc.HandNote.handNote['`@value']",
                            "type": "label"
                          },
                          {
                            "value": "$itemData#$.HandDesc.HandNote.Locus.locus['`@value']",
                            "type": "label"
                          },
                          {
                            "value": {
                              "name": "$itemData#$.HandDesc.Person.name['`@value']",
                              "uri": "$itemData#$.HandDesc.Person.uri['`@value']",
                              "personType": "$itemData#$.HandDesc.Person.personType['`@value']"
                            },
                            "type": "person",
                            "label": "screens.manuscript-details.physical.Source.PhysDesc.Part.HandDesc.Person"
                          }
                        ]
                      },
                      {
                        "elements": [
                          {
                            "value": "$itemData#$.MusicNotation.musicNotation['`@value']",
