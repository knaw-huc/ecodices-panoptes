                          {
                            "value": {
                              "name": "$itemData#$.PersName.persName['`@value']",
                              "uri": "$itemData#$.PersName.personUri['`@value']",
                              "personType": "$itemData#$.PersName.personType['`@value']"
                            },
                            "type": "person",
                            "label": "screens.manuscript-details.history.Source.History.Provenance.person"
                          }
                        ]
                      }
                    ]
                  }
                }
              },
              {
                "type": "array",
                "value": "$data#$.Source.History.Acquisition",
                "config": {
                  "itemTemplate": {
                    "rows": [
                      {
                        "elements": [
                          {
                            "value": "$itemData#$.acquisition['`@value']",
                            "type": "label"
                          },
                          {
                            "value": {
                              "name": "$itemData#$.PersName.persName['`@value']",
                              "uri": "$itemData#$.PersName.personUri['`@value']",
                              "personType": "$itemData#$.PersName.personType['`@value']"
                            },
                            "type": "person",
                            "label": "screens.manuscript-details.history.Source.History.Acquisition.person"
                          }
                        ]
                      }
                    ]
                  }
                }
              }
            ]
          }
        ]
      },
      {
        "displayType": "group",
        "groupId": "bibliography",
        "columns": [
          {
            "elements": [
              {
                "type": "array",
                "value": "$data#$.Source.Additional.Bibliography.onlineResource",
                "config": {
                  "itemTemplate": {
                    "resource": {
                      "value": "$itemData#$['`@value']",
                      "type": "external-link"
                    }
                  }
                }
              },
              {
                "value": "$data#$.Source.Additional.Bibliography.note['`@value']",
                "type": "label"
              },
              {
                "type": "array",
                "value": "$data#$.Source.Additional.Bibliography.Bibliography",
                "config": {
                  "itemTemplate": {
                    "shortTitle": {
                      "value": "$itemData#$.shortTitle['`@value']",
                      "type": "label"
                    },
                    "link": {
                      "value": "$itemData#$.zoteroGroupItemLink['`@value']",
                      "type": "external-link"
                    },
                    "pageRange": {
                      "value": "$itemData#$.pageRange['`@value']",
                      "type": "label"
                    }
                  }
                }
              }
            ]
          }
        ]
      },
      {
        "displayType": "group",
        "groupId": "record-information",
        "columns": [
          {
            "elements": [
              {
                "value": "$data#$.Title.creator",
                "type": "array",
                "config": {
                  "itemTemplate": {
                    "name": {
                      "value": "$itemData#$['`@value']",
                      "type": "label"
                    }
                  }
                }
              },
              {
                "value": "$data#$.Publication.publisher['`@value']",
                "type": "label"
              },
              {
                "value": "$data#$.Source.Additional.Availability.state['`@value']",
                "type": "label"
              },
              {
                "value": "$data#$.Source.Additional.Availability.licence['`@value']",
                "type": "label"
              },
              {
                "value": "$data#$.Source.Additional.Availability.licenceUri['`@value']",
                "type": "external-link"
              },
              {
                "value": "$data#$.Publication.manifestUri['`@value']",
                "type": "external-link"
              }
            ]
          }
        ]
      }
    ]
  }
}